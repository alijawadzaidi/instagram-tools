# --- database (REQUIRED) ---
# Postgres connection string; jobs are persisted here.
DATABASE_URL=postgresql://localhost:5432/instagram_tools

# --- internal auth (REQUIRED unless AUTH_DISABLED=true) ---
# Shared secret between the Next.js BFF proxy and this API. Any long random
# string; must match INTERNAL_API_KEY in apps/web/.env.local.
INTERNAL_API_KEY=dev-internal-key-change-me

# --- dev auth bypass ---
# Set AUTH_DISABLED=true to run with NO authentication (no OAuth, no session,
# no internal key) and attribute everything to a synthetic dev user. It is
# IGNORED when ENVIRONMENT=production, so it can't leak to prod. The same var
# drives the frontend too: `AUTH_DISABLED=true pnpm dev` covers both apps.
# AUTH_DISABLED=true
# ENVIRONMENT=development

# --- transcription engine ---
# local_whisper (free, dev) | openai (prod) | assemblyai (speaker labels)
TRANSCRIBE_ENGINE=local_whisper
WHISPER_MODEL=base

# Needed only for the matching cloud engine:
# OPENAI_API_KEY=sk-...
# ASSEMBLYAI_API_KEY=...

# --- AI tools (LLM) ---
# Default provider for AI tools: anthropic | openai. LLM_MODEL is optional
# (omit to use the provider's default). Set the key for whichever you use.
# LLM_PROVIDER=anthropic
# LLM_MODEL=
# ANTHROPIC_API_KEY=sk-ant-...
# (OPENAI_API_KEY above is reused when LLM_PROVIDER=openai)

# --- Instagram downloader ---
# Path to a Netscape cookies.txt from a logged-in browser.
# Optional locally; effectively REQUIRED when hosted (IG blocks server IPs).
# IG_COOKIES_FILE=/path/to/cookies.txt

# --- CORS: where the Next.js frontend runs ---
CORS_ORIGINS=http://localhost:3000
