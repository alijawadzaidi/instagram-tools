# --- transcription engine ---
# local_whisper (free, dev) | openai (prod) | assemblyai (speaker labels)
TRANSCRIBE_ENGINE=local_whisper
WHISPER_MODEL=base

# Needed only for the matching cloud engine:
# OPENAI_API_KEY=sk-...
# ASSEMBLYAI_API_KEY=...

# --- Instagram downloader ---
# Path to a Netscape cookies.txt from a logged-in browser.
# Optional locally; effectively REQUIRED when hosted (IG blocks server IPs).
# IG_COOKIES_FILE=/path/to/cookies.txt

# --- CORS: where the Next.js frontend runs ---
CORS_ORIGINS=http://localhost:3000
