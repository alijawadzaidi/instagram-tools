{
  "name": "instagram-tools",
  "version": "0.1.0",
  "private": true,
  "description": "A scalable collection of tools for Instagram users. Tool #1: Reel Transcriber.",
  "scripts": {
    "dev": "concurrently -k -n web,api -c cyan,magenta \"pnpm dev:web\" \"pnpm dev:api\"",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "cd apps/api && .venv/bin/uvicorn app.main:app --reload --port 8000",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "web": "pnpm --filter web"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "turbo": "^2.5.0"
  },
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=20.9.0"
  }
}
